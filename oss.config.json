{
  "$schema": "https://json-schema.org/draft/07/schema#",
  "title": "阿里云 OSS 部署配置",
  "description": "用于部署静态网站到阿里云 OSS 的配置文件",
  "type": "object",
  "properties": {
    "region": {
      "type": "string",
      "description": "OSS 区域，如：oss-cn-hangzhou、oss-cn-beijing 等",
      "examples": [
        "oss-cn-hangzhou",
        "oss-cn-beijing",
        "oss-cn-shanghai",
        "oss-cn-shenzhen",
        "oss-cn-guangzhou"
      ]
    },
    "bucket": {
      "type": "string",
      "description": "OSS 存储桶名称"
    },
    "accessKeyId": {
      "type": "string",
      "description": "阿里云 AccessKey ID（建议使用环境变量）"
    },
    "accessKeySecret": {
      "type": "string",
      "description": "阿里云 AccessKey Secret（建议使用环境变量）"
    },
    "cdnDomain": {
      "type": "string",
      "description": "CDN 加速域名（可选，如配置了 CDN）"
    },
    "uploadPath": {
      "type": "string",
      "description": "OSS 中的上传路径，默认为根目录",
      "default": ""
    },
    "exclude": {
      "type": "array",
      "description": "排除的文件或目录",
      "items": {
        "type": "string"
      },
      "default": [
        "*.map",
        ".DS_Store",
        "Thumbs.db"
      ]
    },
    "cacheControl": {
      "type": "string",
      "description": "缓存控制策略",
      "default": "max-age=31536000"
    },
    "contentType": {
      "type": "object",
      "description": "文件类型映射",
      "additionalProperties": {
        "type": "string"
      },
      "default": {
        ".html": "text/html; charset=utf-8",
        ".css": "text/css; charset=utf-8",
        ".js": "application/javascript; charset=utf-8",
        ".json": "application/json; charset=utf-8",
        ".png": "image/png",
        ".jpg": "image/jpeg",
        ".jpeg": "image/jpeg",
        ".gif": "image/gif",
        ".svg": "image/svg+xml",
        ".ico": "image/x-icon",
        ".woff": "font/woff",
        ".woff2": "font/woff2",
        ".ttf": "font/ttf",
        ".eot": "application/vnd.ms-fontobject"
      }
    }
  },
  "required": ["region", "bucket", "accessKeyId", "accessKeySecret"]
}
